/*
 * -------------------------------------------------
 * Nextflow config file
 * -------------------------------------------------
 * Default config options for all environments.
*/

manifest {
    description = 'Compile LaTeX Beamer documents'
    homePage = 'https://github.com/maxulysse/compile-latex'
    nextflowVersion = '>=25.10.2'
    author = 'MaxUlysse'
    version = '2.3'
}

params {
    biblio = 'biblio.bib'
    help = false
    notes = ''
    notes_only = ''
    outdir = System.getenv('PWD')
    outname = ''
    pictures = 'pictures'
}

process {
    scratch = true
    shell = ['/bin/bash', '-xeuo', 'pipefail']
}

docker {
    enabled = true
    fixOwnership = true
}

profiles {
    test {
        params.tex = 'sample.tex'
    }
}
