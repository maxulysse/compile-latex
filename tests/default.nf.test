nextflow_pipeline {

    name "Test pipeline"
    script "../main.nf"
    tag "pipeline"

    test("-profile test") {

        options "-output-dir ${outputDir}"

        when {
            params {
                outdir = "${outputDir}"
            }
        }

        then {
            // stable_name: All files + folders in ${outputDir}/ with a stable name
            def stable_name = getAllFilesFromDir(outputDir, relative: true, includeDir: true, ignore: ['pipeline_info/*.{html,json,txt}'])
            // stable_content: All files in ${outputDir}/ with stable content
            def stable_content = getAllFilesFromDir(outputDir, ignoreFile: 'tests/.nftignore')

            assert workflow.success
            assertAll(
                { assert snapshot(
                    // Number of successful tasks
                    workflow.trace.succeeded().size(),
                    // All stable path name, with a relative path
                    stable_name,
                    // All files with stable contents
                    stable_content.isEmpty() ? 'No stable content' : stable_content
                ).match() }
            )
        }
    }
}